# Host port used by the server reverse proxy.
APP_PORT=10000

# Local build default. Production will use the Docker Hub image and immutable tag.
APP_IMAGE=fold-web:local

# Local PostgreSQL defaults. Production values are injected by the deployment
# secret manager and must not be committed.
DATABASE_URL=postgresql://fold_web_app@127.0.0.1:5432/fold_web_dev?schema=public
MIGRATION_DATABASE_URL=postgresql://fold_web_migrator@127.0.0.1:5432/fold_web_dev?schema=public
SHADOW_DATABASE_URL=postgresql://fold_web_migrator@127.0.0.1:5432/fold_web_shadow?schema=public
TEST_DATABASE_URL=postgresql://fold_web_app@127.0.0.1:5432/fold_web_test?schema=public
TEST_MIGRATION_DATABASE_URL=postgresql://fold_web_migrator@127.0.0.1:5432/fold_web_test?schema=public

# Server runtime pool and timeout defaults.
DATABASE_CONNECTION_LIMIT=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=10000
DATABASE_STATEMENT_TIMEOUT_MS=5000

# Optional internal integration endpoint. Leave unset in normal operation.
# Use a random value of at least 32 characters only during an authorized test.
INTERNAL_SMOKE_TOKEN=

# Offline importer only. Keep empty unless a read-only legacy reference
# connection is explicitly required.
LEGACY_REFERENCE_DATABASE_URL=
