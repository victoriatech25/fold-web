{
  "name": "fold_web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:e2e": "node scripts/prepare-e2e.mjs && playwright test",
    "auth:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "auth:issue-password-reset": "tsx scripts/issue-password-reset.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate:check": "prisma migrate diff --exit-code --from-migrations prisma/migrations --to-schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "prisma db seed",
    "db:test:reset": "node scripts/reset-test-db.mjs"
  },
  "dependencies": {
    "@node-rs/argon2": "2.0.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@zxcvbn-ts/core": "4.1.2",
    "@zxcvbn-ts/language-common": "4.1.3",
    "konva": "^10.3.0",
    "lucide-react": "^1.24.0",
    "mobx": "^6.16.1",
    "mobx-react-lite": "^4.1.1",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-konva": "^19.2.5",
    "server-only": "0.0.1",
    "three": "^0.185.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "7.8.0",
    "tailwindcss": "^4",
    "tsx": "4.23.1",
    "typescript": "^5",
    "vitest": "^3.2.7"
  }
}
